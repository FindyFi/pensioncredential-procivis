{
  "name": "Todistus Kelan eläkkeestä",
  "translations": {
    "name": {
      "en": "Kela Pension Credential",
      "fi": "Todistus Kelan eläkkeestä",
      "sv": "Intyg om pension från Kela"
    },
    "description": {
      "en": "The subject receives pension from Kela",
      "fi": "Todisteessa mainittu henkilö saa Kelan maksamaa eläkettä",
      "sv": "Mottagaren får pension från Kela"
    }
  },
  "formats": [
    {
      "format": "SD_JWT_VC",
      "schemaId": "https://alennusperuste.todiste.fi/credentials/v2/PensionCredential"
    }
  ],
  "allowRevocation": false,
  "allowSuspension": false,
  "requiresWalletInstanceAttestation": false,
  "claims": [
   {
    "key": "Pension",
    "required": false,
    "datatype": "OBJECT",
    "translations": {
     "name": {
      "en": "Pension",
      "fi": "Eläke",
      "sv": "Pension"
     }
    },
    "claims": [
     {
      "key": "effectual",
      "required": false,
      "datatype": "BOOLEAN",
      "translations": {
       "name": {
        "en": "The pension decision is effectual",
        "fi": "Eläkepäätös on voimassa",
        "sv": "Pensionsbeslutet är giltigt"
       }
      }
     }
    ]
   },
   {
    "key": "Person",
    "required": true,
    "datatype": "OBJECT",
    "translations": {
     "name": {
      "en": "Person",
      "fi": "Henkilö",
      "sv": "Person"
     }
    },
    "claims": [
     {
      "key": "personal_administrative_number",
      "required": true,
      "datatype": "STRING",
      "translations": {
       "name": {
        "en": "The unique personal identifier of the pension recipient",
        "fi": "Eläkkeensaajan yksilöivä henkilötunnus",
        "sv": "Pensionsmottagarens unika personbeteckning"
       }
      }
     }
    ]
   }
  ],
  "layoutType": "CARD",
  "layoutProperties": {
   "background": {
    "color": "#0a00be"
   },
   "logo": {
    "image": "data:image/png;base64,"
   },
   "primaryAttribute": "Person/personal_administrative_number",
   "secondaryAttribute": "Pension/effectual"
  }
}
